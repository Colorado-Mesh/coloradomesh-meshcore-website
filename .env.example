# Optional Docker Compose overrides.
IMAGE_NAME=colorado-meshcore-site
WEB_PORT=3000

# Public site URL used for metadata, sitemap, and canonical links.
NEXT_PUBLIC_SITE_URL=https://meshcore.coloradomesh.org

# Runtime Leaflet tile settings exposed through /api/map/runtime. The default is OpenStreetMap if unset.
MESHCORE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
MESHCORE_MAP_TILE_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors
MESHCORE_MAP_DEFAULT_LATITUDE=39.5501
MESHCORE_MAP_DEFAULT_LONGITUDE=-105.7821
MESHCORE_MAP_DEFAULT_ZOOM=7

# Fake/sample nodes are disabled by default. Set both values below to true only for an intentional demo.
MESHCORE_MAP_SAMPLE_DATA=false
MESHCORE_MAP_DEMO_MODE=false

# Legacy Next live-map compatibility APIs. CoreScope is served at /map in Docker,
# but these remain available for tools that still call /api/live-map/*.
MESHCORE_LIVE_MAP_API_URL=http://127.0.0.1:3002/api/nodes
MESHCORE_LIVE_MAP_API_TOKEN=
MESHCORE_LIVE_MAP_ALLOW_PRIVATE_URLS=true
MESHCORE_LIVE_MAP_PUBLIC_TOKEN_PROXY_ENABLED=false
MESHCORE_LIVE_MAP_API_REFRESH_SECONDS=30
MESHCORE_LIVE_MAP_PROXY_TIMEOUT_MS=8000
MESHCORE_LIVE_MAP_PROXY_MAX_RESPONSE_BYTES=2000000

# Set true only behind a trusted reverse proxy that scrubs inbound forwarding headers.
MESHCORE_TRUST_PROXY_HEADERS=false

# CoreScope runtime config. Secrets stay in the runtime environment and are written
# only inside the container to /app/corescope/config.json.
CORESCOPE_ENABLE_INGESTOR=auto
CORESCOPE_API_KEY=
CORESCOPE_BRAND_SITE_NAME=Colorado Mesh CoreScope
CORESCOPE_BRAND_TAGLINE=Live Colorado Mesh network analyzer
CORESCOPE_DEFAULT_REGION=CO
CORESCOPE_REGIONS_JSON={"CO":"Colorado, US"}
CORESCOPE_MAP_CENTER_LAT=39.5501
CORESCOPE_MAP_CENTER_LON=-105.7821
CORESCOPE_MAP_ZOOM=7
CORESCOPE_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# CoreScope MQTT ingestion. Leave broker/server empty for no-secret local startup.
# Either set CORESCOPE_MQTT_BROKER directly (mqtts://host:8883 or wss://host:8883),
# or set server/port/transport/tls and let the runtime config renderer build it.
CORESCOPE_MQTT_BROKER=
CORESCOPE_MQTT_SERVER=meshcore_mqtt.coloradomesh.org
CORESCOPE_MQTT_PORT=8883
CORESCOPE_MQTT_TRANSPORT=websockets
CORESCOPE_MQTT_TLS_ENABLED=true
CORESCOPE_MQTT_TOPICS=meshcore/#
CORESCOPE_MQTT_USERNAME=website
CORESCOPE_MQTT_PASSWORD=
CORESCOPE_MQTT_PASSWORD_FILE=
CORESCOPE_MQTT_SOURCE_NAME=coloradomesh
CORESCOPE_MQTT_REGION=CO
CORESCOPE_MQTT_IATA_FILTER=
CORESCOPE_MQTT_REJECT_UNAUTHORIZED=true
CORESCOPE_MQTT_CONNECT_TIMEOUT_SEC=45
# Advanced multi-source override, e.g. [{"name":"co","broker":"mqtts://broker:8883","topics":["meshcore/#"]}]
CORESCOPE_MQTT_SOURCES_JSON=

# Optional CoreScope filters and channel decryption settings.
CORESCOPE_CHANNEL_KEYS_JSON={}
CORESCOPE_HASH_CHANNELS=
CORESCOPE_OBSERVER_IATA_WHITELIST=
CORESCOPE_NODE_BLACKLIST=
CORESCOPE_OBSERVER_BLACKLIST=

# CoreScope retention and memory defaults.
CORESCOPE_RETENTION_NODE_DAYS=7
CORESCOPE_RETENTION_OBSERVER_DAYS=14
CORESCOPE_RETENTION_PACKET_DAYS=30
CORESCOPE_RETENTION_METRICS_DAYS=30
CORESCOPE_PACKET_STORE_MAX_MEMORY_MB=1024
CORESCOPE_PACKET_STORE_RETENTION_HOURS=168

# Reserved for future map history support.
MESHCORE_MAP_HISTORY_ENABLED=false
